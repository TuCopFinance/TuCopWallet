access":"public","severity":"high","module_name":"h3","vulnerable_versions":"<1.15.6","github_advisory_id":"GHSA-22cc-p3c6-wpvm","recommendation":"Upgrade to version 1.15.6 or later","patched_versions":">=1.15.6","updated":"2026-03-20T21:27:42.000Z","cvss":{"score":7.5,"vectorString":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:C/C:L/I:H/A:N"},"cwe":["CWE-93"],"url":"https://github.com/advisories/GHSA-22cc-p3c6-wpvm"}}}
