+
+internal fun windowsAwareCommandLine(args: List<Any>): List<Any> =
+    if (Os.isWindows()) {
+      listOf("cmd", "/c") + args
+    } else {
+      args
+    }
+
+internal fun windowsAwareBashCommandLine(
+    vararg args: String,
+    bashWindowsHome: String? = null
+): List<String> =
+    if (Os.isWindows()) {
+      listOf(bashWindowsHome ?: "bash", "-c") + args
+    } else {
+      args.toList()
+    }
